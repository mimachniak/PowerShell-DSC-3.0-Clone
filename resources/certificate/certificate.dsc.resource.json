{
    "$schema": "https://aka.ms/dsc/schemas/v3/bundled/resource/manifest.json",
    "type": "Microsoft.Windows/Certificate",
    "description": "Manage Windows certificate store - get, set, test, delete and export certificates",
    "tags": [
        "Windows",
        "Security",
        "Certificate"
    ],
    "version": "0.1.0",
    "get": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "certificate.ps1",
            "get"
        ],
        "input": "stdin"
    },
    "set": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "certificate.ps1",
            "set"
        ],
        "input": "stdin",
        "implementsPretest": true,
        "return": "state"
    },
    "test": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "certificate.ps1",
            "test"
        ],
        "input": "stdin",
        "return": "state"
    },
    "delete": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "certificate.ps1",
            "delete"
        ],
        "input": "stdin"
    },
    "export": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "certificate.ps1",
            "export"
        ]
    },
    "exitCodes": {
        "0": "Success",
        "1": "Error - operation failed",
        "2": "Certificate not found",
        "3": "Invalid input",
        "4": "Access denied",
        "5": "Store not found"
    },
    "schema": {
        "embedded": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "title": "Certificate",
            "type": "object",
            "required": [
                "storeName"
            ],
            "properties": {
                "thumbprint": {
                    "type": "string",
                    "description": "The certificate thumbprint (SHA1 hash)"
                },
                "subject": {
                    "type": "string",
                    "description": "The certificate subject name (e.g., CN=MyCert)"
                },
                "storeName": {
                    "type": "string",
                    "description": "Certificate store name",
                    "enum": [
                        "My",
                        "Root",
                        "CA",
                        "TrustedPublisher",
                        "TrustedPeople",
                        "AuthRoot",
                        "Disallowed"
                    ],
                    "default": "My"
                },
                "storeLocation": {
                    "type": "string",
                    "description": "Certificate store location",
                    "enum": [
                        "CurrentUser",
                        "LocalMachine"
                    ],
                    "default": "CurrentUser"
                },
                "friendlyName": {
                    "type": "string",
                    "description": "The certificate friendly name"
                },
                "issuer": {
                    "type": "string",
                    "description": "The certificate issuer"
                },
                "notBefore": {
                    "type": "string",
                    "description": "Certificate validity start date (ISO 8601 format)"
                },
                "notAfter": {
                    "type": "string",
                    "description": "Certificate validity end date (ISO 8601 format)"
                },
                "hasPrivateKey": {
                    "type": "boolean",
                    "description": "Whether the certificate has a private key"
                },
                "dnsNameList": {
                    "type": "array",
                    "description": "List of DNS names in the certificate",
                    "items": {
                        "type": "string"
                    }
                },
                "enhancedKeyUsageList": {
                    "type": "array",
                    "description": "List of enhanced key usage OIDs",
                    "items": {
                        "type": "string"
                    }
                },
                "ensure": {
                    "type": "string",
                    "description": "Desired state of the certificate",
                    "enum": [
                        "Present",
                        "Absent"
                    ],
                    "default": "Present"
                },
                "pfxPath": {
                    "type": "string",
                    "description": "Path to PFX file for import"
                },
                "pfxPassword": {
                    "type": "string",
                    "description": "Password for PFX file (use secure string in production)"
                },
                "exportPath": {
                    "type": "string",
                    "description": "Path to export certificate (for export operation)"
                },
                "exportType": {
                    "type": "string",
                    "description": "Export format",
                    "enum": [
                        "Cert",
                        "Pfx"
                    ],
                    "default": "Cert"
                },
                "_inDesiredState": {
                    "type": "boolean",
                    "description": "Indicates if certificate is in desired state"
                }
            },
            "additionalProperties": false
        }
    }
}
